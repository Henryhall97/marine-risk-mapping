# Production environment variables — copy to .env and fill in real values.
# DO NOT commit the real .env file.

# ── Database ────────────────────────────────────────────────
POSTGRES_DB=marine_risk
POSTGRES_USER=marine
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=replace-me-with-a-long-random-string

# ── Auth (FastAPI JWT) ──────────────────────────────────────
# Generate with: openssl rand -hex 32
MR_JWT_SECRET=replace-me-with-a-long-random-string

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list. Add your Vercel URL (preview + prod).
MR_CORS_ORIGINS=https://marine-risk.vercel.app,https://marine-risk-git-main-yourname.vercel.app

# ── Public domain (for Caddy / TLS) ─────────────────────────
# Point an A record at the VM's public IP first, then set this.
DOMAIN=api.marinerisk.example.com
