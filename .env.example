# Marine Risk Mapping — environment variables
# Copy to .env and fill in real values:  cp .env.example .env
# .env is git-ignored and never committed.

# ── Database (used by pipeline/config.py AND transform/profiles.yml) ──
MR_DB_HOST=localhost
MR_DB_PORT=5433
MR_DB_NAME=marine_risk
MR_DB_USER=marine
MR_DB_PASSWORD=change_me

# ── Docker Compose (used by docker/docker-compose.yml) ──
# These map to POSTGRES_* vars inside the container.
POSTGRES_DB=marine_risk
POSTGRES_USER=marine
POSTGRES_PASSWORD=change_me

# ── Optional: remote ArcFace training on AWS / EC2 ──
MR_AWS_TRAIN_HOST=
MR_AWS_TRAIN_USER=ubuntu
MR_AWS_TRAIN_PORT=22
MR_AWS_TRAIN_IDENTITY_FILE=~/.ssh/your-ec2-key.pem
MR_AWS_TRAIN_REMOTE_DIR=~/marine_risk_mapping
